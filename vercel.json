{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "artifacts/placementbridge/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/artifacts/placementbridge/dist/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/artifacts/placementbridge/dist/public/index.html"
    }
  ],
  "env": {
    "PNPM_VERSION": "10.33.2"
  }
}
